# ---------------------------------------------------------------------------
# Supabase — Project → Settings → API
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. NEVER expose to the browser. Used for all admin writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# Access control (no user accounts)
# ---------------------------------------------------------------------------
# NOTE: The public site is OPEN to everyone — this allowlist is NOT enforced.
# (Kept for reference; re-enable the IP gate in src/middleware.ts if ever needed.)
ALLOWED_IPS=

# Shared passcode that unlocks the /admin dashboard.
ADMIN_PASSCODE=change-me-to-a-strong-passphrase

# Secret used to sign the admin session cookie (any long random string).
ADMIN_SESSION_SECRET=generate-a-64-char-random-string-here

# Set true if your app runs behind a proxy/CDN and you trust X-Forwarded-For.
TRUST_PROXY=true

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=NS Knowledge Base
